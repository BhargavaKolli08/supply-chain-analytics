CREATE OR REPLACE DATABASE SUPPLY_CHAIN_DB;

CREATE OR REPLACE SCHEMA SUPPLY_CHAIN_DB.RAW;
CREATE OR REPLACE SCHEMA SUPPLY_CHAIN_DB.TRANSFORMED;
CREATE OR REPLACE SCHEMA SUPPLY_CHAIN_DB.MART;

create warehouse SUPPLY_CHAIN_WH with WAREHOUSE_SIZE = 'XSMALL' AUTO_SUSPEND = 120 AUTO_RESUME = TRUE DEFAULT_WAREHOUSE = TRUE;

use warehouse SUPPLY_CHAIN_WH;
use database SUPPLY_CHAIN_DB;
use schema RAW;

CREATE OR REPLACE FILE FORMAT CSV_FORMAT
  TYPE = 'CSV'
  FIELD_DELIMITER = ','
  FIELD_OPTIONALLY_ENCLOSED_BY = '"'
  SKIP_HEADER = 1
  empTY_FIELD_AS_NULL = TRUE
  TRIM_SPACE = TRUE
  ENCODING = 'windows-1252';


CREATE OR REPLACE STAGE S3_STAGE_ORDERS
  URL = 's3://supply-chain-analytics-bk/raw/orders/'
  STORAGE_INTEGRATION = S3_role_integration
  FILE_FORMAT = CSV_FORMAT;

LIST @S3_STAGE_ORDERS;

SELECT *
FROM TABLE(
  INFER_SCHEMA(
    LOCATION => '@S3_STAGE_ORDERS',
    FILE_FORMAT => 'CSV_FORMAT'
  )
);

CREATE OR REPLACE TABLE RAW.ORDERS
USING TEMPLATE (
  SELECT ARRAY_AGG(OBJECT_CONSTRUCT(*))
  FROM TABLE(
    INFER_SCHEMA(
      LOCATION => '@S3_STAGE_ORDERS/',
      FILE_FORMAT => 'CSV_FORMAT'
    )
  )
);


COPY INTO RAW.ORDERS
FROM @S3_STAGE_ORDERS
FILE_FORMAT = (FORMAT_NAME = CSV_FORMAT)
ON_ERROR = 'CONTINUE';

SELECT * FROM SUPPLY_CHAIN_DB.RAW.ORDERS limit 10;

CREATE OR REPLACE TABLE TRANSFORMED.STG_ORDERS AS
SELECT
    "c1" AS TYPE,
    "c2" AS DAYS_FOR_SHIPPING_REAL,
    "c3" AS DAYS_FOR_SHIPMENT_SCHEDULED,
    "c4" AS BENEFIT_PER_ORDER,
    "c5" AS SALES_PER_CUSTOMER,
    "c6" AS DELIVERY_STATUS,
    "c7" AS LATE_DELIVERY_RISK,
    TRIM("c8") AS CATEGORY_ID,
    TRIM("c9") AS CATEGORY_NAME,
    TRIM("c10") AS CUSTOMER_CITY,
    TRIM("c11") AS CUSTOMER_COUNTRY,
    TRIM("c12") AS CUSTOMER_EMAIL,
    TRIM("c13") AS CUSTOMER_FNAME,
    TRIM("c14") AS CUSTOMER_ID,
    TRIM("c15") AS CUSTOMER_LNAME,
    TRIM("c16") AS CUSTOMER_PASSWORD,
    TRIM("c17") AS CUSTOMER_SEGMENT,
    TRIM("c18") AS CUSTOMER_STATE,
    TRIM("c19") AS CUSTOMER_STREET,
    TRIM("c20") AS CUSTOMER_ZIPCODE,
    TRIM("c21") AS DEPARTMENT_ID,
    TRIM("c22") AS DEPARTMENT_NAME,
    "c23" AS LATITUDE,
    "c24" AS LONGITUDE,
    TRIM("c25") AS MARKET,
    TRIM("c26") AS ORDER_CITY,
    TRIM("c27") AS ORDER_COUNTRY,
    "c28" AS ORDER_CUSTOMER_ID,
    TRY_TO_TIMESTAMP(TRIM("c29"), 'MM/DD/YYYY HH24:MI') AS ORDER_DATE,
    TRIM("c30") AS ORDER_ID,
    "c31" AS ORDER_ITEM_CARDPROD_ID,
    "c32" AS ORDER_ITEM_DISCOUNT,
    "c33" AS ORDER_ITEM_DISCOUNT_RATE,
    TRIM("c34") AS ORDER_ITEM_ID,
    TRIM("c35") AS ORDER_ITEM_PRODUCT_PRICE,
    TRIM("c36") AS ORDER_ITEM_PROFIT_RATIO,
    TRIM("c37") AS ORDER_ITEM_QUANTITY,
    TRIM("c38") AS SALES,
    TRIM("c39") AS ORDER_ITEM_TOTAL,
    TRIM("c40") AS ORDER_PROFIT_PER_ORDER,
    TRIM("c41") AS ORDER_REGION,
    TRIM("c42") AS ORDER_STATE,
    TRIM("c43") AS ORDER_STATUS,
    TRIM("c44") AS PRODUCT_CARD_ID,
    TRIM("c45") AS PRODUCT_CATEGORY_ID,
    TRIM("c46") AS PRODUCT_DESCRIPTION,
    TRIM("c48") AS PRODUCT_IMAGE,
    TRIM("c49") AS PRODUCT_NAME,
    TRIM("c50") AS PRODUCT_PRICE,
    TRIM("c51") AS PRODUCT_STATUS,
    TRY_TO_TIMESTAMP(TRIM("c52"), 'MM/DD/YYYY HH24:MI') AS SHIPPING_DATE,
    TRIM("c53") AS SHIPPING_MODE,
    DATEDIFF(day, TRY_TO_TIMESTAMP(TRIM("c29"), 'MM/DD/YYYY HH24:MI'), TRY_TO_TIMESTAMP(TRIM("c52"), 'MM/DD/YYYY HH24:MI')) AS DAYS_BETWEEN_ORDER_AND_SHIP
FROM RAW.ORDERS;
DESC TABLE RAW.ORDERS; 
DESC TABLE TRANSFORMED.STG_ORDERS;

SELECT
    COUNT_IF(ORDER_DATE IS NULL) AS NULL_ORDER_DATE,
    COUNT_IF(SHIPPING_DATE IS NULL) AS NULL_SHIPPING_DATE,
    COUNT_IF(DAYS_BETWEEN_ORDER_AND_SHIP IS NULL) AS NULL_DAYS_BETWEEN
FROM TRANSFORMED.STG_ORDERS;

SELECT * FROM TRANSFORMED.STG_ORDERS
LIMIT 10;

CREATE OR REPLACE TABLE MART.FACT_ORDERS AS
SELECT
    ORDER_ID,
    ORDER_DATE,
    SHIPPING_DATE,
    SHIPPING_MODE,
    DELIVERY_STATUS,
    MARKET,
    ORDER_REGION,
    ORDER_COUNTRY,
    ORDER_CITY,
    CATEGORY_NAME,
    PRODUCT_NAME,
    CUSTOMER_SEGMENT,
    ORDER_ITEM_QUANTITY,
    SALES,
    ORDER_ITEM_TOTAL,
    ORDER_PROFIT_PER_ORDER,
    DAYS_FOR_SHIPPING_REAL,
    DAYS_FOR_SHIPMENT_SCHEDULED,
    DAYS_BETWEEN_ORDER_AND_SHIP,
    LATE_DELIVERY_RISK
FROM TRANSFORMED.STG_ORDERS;